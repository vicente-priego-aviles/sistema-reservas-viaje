# ===========================================================
# connector-secrets.txt — Variables de entorno para Camunda Connectors
#
# Este archivo es requerido por docker-compose-camunda.yml.
# NO se sube al repositorio (está en .gitignore).
#
# INSTRUCCIONES:
#   Copia este archivo y renómbralo:
#     cp connector-secrets.txt.example connector-secrets.txt
#
#   Para desarrollo local puedes dejarlo vacío.
#   Si usas Camunda Connectors (HTTP, Slack, etc.), añade aquí
#   las variables de entorno necesarias. Ejemplo:
#
# SLACK_TOKEN=xoxb-tu-token
# SENDGRID_API_KEY=SG.tu-api-key
# ===========================================================
