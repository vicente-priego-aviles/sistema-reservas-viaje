{
  "components": [
    {
      "text": "# 🎯 Iniciar Reserva de Viaje\n\nComplete los datos para iniciar el proceso de reserva.",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_0", "columns": null },
      "id": "Field_Header"
    },
    {
      "text": "---",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_1", "columns": null },
      "id": "Field_Divider_1"
    },
    {
      "text": "## 👤 Datos del Cliente",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_2", "columns": null },
      "id": "Field_ClienteHeader"
    },
    {
      "label": "Cliente",
      "type": "select",
      "layout": { "row": "Row_3", "columns": null },
      "id": "clienteId",
      "key": "clienteId",
      "description": "Selecciona el cliente que realizará la reserva",
      "valuesExpression": "=clientesDisponibles",
      "validate": { "required": true }
    },
    {
      "text": "---",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_4", "columns": null },
      "id": "Field_Divider_2"
    },
    {
      "text": "## 🗺️ Detalles del Viaje",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_5", "columns": null },
      "id": "Field_ViajeHeader"
    },
    {
      "label": "Destino",
      "type": "select",
      "layout": { "row": "Row_6", "columns": null },
      "id": "destino",
      "key": "destino",
      "description": "Capital de provincia de destino",
      "values": [
        { "label": "A Coruña", "value": "A Coruña" },
        { "label": "Albacete", "value": "Albacete" },
        { "label": "Alicante", "value": "Alicante" },
        { "label": "Almería", "value": "Almería" },
        { "label": "Ávila", "value": "Ávila" },
        { "label": "Badajoz", "value": "Badajoz" },
        { "label": "Bilbao", "value": "Bilbao" },
        { "label": "Burgos", "value": "Burgos" },
        { "label": "Cáceres", "value": "Cáceres" },
        { "label": "Cádiz", "value": "Cádiz" },
        { "label": "Castellón de la Plana", "value": "Castellón de la Plana" },
        { "label": "Ceuta", "value": "Ceuta" },
        { "label": "Ciudad Real", "value": "Ciudad Real" },
        { "label": "Córdoba", "value": "Córdoba" },
        { "label": "Cuenca", "value": "Cuenca" },
        { "label": "Girona", "value": "Girona" },
        { "label": "Granada", "value": "Granada" },
        { "label": "Guadalajara", "value": "Guadalajara" },
        { "label": "Huelva", "value": "Huelva" },
        { "label": "Huesca", "value": "Huesca" },
        { "label": "Jaén", "value": "Jaén" },
        { "label": "Las Palmas de Gran Canaria", "value": "Las Palmas de Gran Canaria" },
        { "label": "León", "value": "León" },
        { "label": "Lleida", "value": "Lleida" },
        { "label": "Logroño", "value": "Logroño" },
        { "label": "Lugo", "value": "Lugo" },
        { "label": "Madrid", "value": "Madrid" },
        { "label": "Málaga", "value": "Málaga" },
        { "label": "Melilla", "value": "Melilla" },
        { "label": "Murcia", "value": "Murcia" },
        { "label": "Ourense", "value": "Ourense" },
        { "label": "Oviedo", "value": "Oviedo" },
        { "label": "Palencia", "value": "Palencia" },
        { "label": "Palma", "value": "Palma" },
        { "label": "Pamplona", "value": "Pamplona" },
        { "label": "Pontevedra", "value": "Pontevedra" },
        { "label": "Salamanca", "value": "Salamanca" },
        { "label": "San Sebastián", "value": "San Sebastián" },
        { "label": "Santa Cruz de Tenerife", "value": "Santa Cruz de Tenerife" },
        { "label": "Santander", "value": "Santander" },
        { "label": "Segovia", "value": "Segovia" },
        { "label": "Sevilla", "value": "Sevilla" },
        { "label": "Soria", "value": "Soria" },
        { "label": "Tarragona", "value": "Tarragona" },
        { "label": "Teruel", "value": "Teruel" },
        { "label": "Toledo", "value": "Toledo" },
        { "label": "Valencia", "value": "Valencia" },
        { "label": "Valladolid", "value": "Valladolid" },
        { "label": "Vitoria-Gasteiz", "value": "Vitoria-Gasteiz" },
        { "label": "Zamora", "value": "Zamora" },
        { "label": "Zaragoza", "value": "Zaragoza" }
      ],
      "validate": { "required": true }
    },
    {
      "label": "Fecha de Inicio",
      "type": "datetime",
      "layout": { "row": "Row_7", "columns": 6 },
      "id": "fechaInicio",
      "key": "fechaInicio",
      "description": "Fecha y hora de inicio del viaje",
      "defaultValue": "=date and time(today() + duration(\"P1D\"), time(\"T10:00:00\"))",
      "validate": { "required": true },
      "dateLabel": "Fecha de Inicio",
      "timeLabel": "Hora de Inicio",
      "use24h": true
    },
    {
      "label": "Fecha de Fin",
      "type": "datetime",
      "layout": { "row": "Row_7", "columns": 6 },
      "id": "fechaFin",
      "key": "fechaFin",
      "description": "Fecha y hora de fin del viaje",
      "defaultValue": "=date and time(today() + duration(\"P1D\"), time(\"T12:00:00\"))",
      "validate": { "required": true },
      "dateLabel": "Fecha de Fin",
      "timeLabel": "Hora de Fin",
      "use24h": true
    },
    {
      "label": "Número de Pasajeros",
      "type": "number",
      "layout": { "row": "Row_8", "columns": 6 },
      "id": "numeroPasajeros",
      "key": "numeroPasajeros",
      "description": "Número de personas que realizarán el viaje (1–10)",
      "validate": {
        "required": true,
        "min": 1,
        "max": 10
      },
      "defaultValue": 1
    },
    {
      "text": "---",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_9", "columns": null },
      "id": "Field_Divider_3"
    },
    {
      "text": "## 📧 Datos de Contacto",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_10", "columns": null },
      "id": "Field_ContactoHeader"
    },
    {
      "label": "Email de Contacto",
      "type": "textfield",
      "layout": { "row": "Row_11", "columns": 6 },
      "id": "emailContacto",
      "key": "emailContacto",
      "description": "Email para recibir notificaciones de la reserva",
      "defaultValue": "reservas@viaje.dev",
      "validate": { "required": true }
    },
    {
      "label": "Teléfono de Contacto",
      "type": "textfield",
      "layout": { "row": "Row_11", "columns": 6 },
      "id": "telefonoContacto",
      "key": "telefonoContacto",
      "description": "Teléfono en formato internacional. Ej: +34600123456",
      "defaultValue": "+34600000000",
      "validate": { "required": true }
    },
    {
      "text": "---",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_12", "columns": null },
      "id": "Field_Divider_4"
    },
    {
      "text": "### ℹ️ Información\n\n- El proceso verificará al cliente y su tarjeta de crédito automáticamente\n- Se reservarán vuelo, hotel y coche en paralelo\n- Si el pago falla, todas las reservas se cancelarán de forma automática (Saga)",
      "label": "Text view",
      "type": "text",
      "layout": { "row": "Row_13", "columns": null },
      "id": "Field_Info"
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.7.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.37.0"
  },
  "schemaVersion": 18,
  "id": "iniciar-reserva",
  "type": "default"
}
