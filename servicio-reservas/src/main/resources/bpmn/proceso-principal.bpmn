<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_ProcesoPrincipal" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <bpmn:process id="proceso-principal" name="Proceso Principal de Reserva de Viaje" isExecutable="true">
    <bpmn:startEvent id="evento-inicio-solicitud-reserva" name="📩 Solicitud de Reserva de Viaje">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="iniciar-reserva" />
        <zeebe:ioMapping>
          <zeebe:output source="=uuid()" target="reservaId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>flujo-inicio-a-validar-datos</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="validar-datos-entrada" name="✅ Validar Datos de Entrada">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validar-datos-entrada" retries="" />
      </bpmn:extensionElements>
      <bpmn:incoming>flujo-inicio-a-validar-datos</bpmn:incoming>
      <bpmn:outgoing>flujo-validar-a-gestion-cliente</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="evento-error-datos-invalidos" name="❌ Error Validación" attachedToRef="validar-datos-entrada">
      <bpmn:outgoing>flujo-error-validacion-a-fin</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDef_ValidacionDatos" errorRef="Error_ValidacionDatos" />
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="evento-fin-datos-invalidos" name="❌ Datos Inválidos">
      <bpmn:incoming>flujo-error-validacion-a-fin</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="call-activity-gestion-cliente" name="👤 Gestión de Cliente">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="subproceso-gestion-cliente" propagateAllChildVariables="true" />
      </bpmn:extensionElements>
      <bpmn:incoming>flujo-validar-a-gestion-cliente</bpmn:incoming>
      <bpmn:outgoing>flujo-gestion-cliente-a-revisar-datos</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:boundaryEvent id="evento-error-gestion-cliente" name="❌ Error Cliente" attachedToRef="call-activity-gestion-cliente">
      <bpmn:outgoing>flujo-error-cliente-a-fin</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDef_GestionCliente" />
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="evento-fin-error-gestion-cliente" name="❌ Error en Gestión de Cliente">
      <bpmn:incoming>flujo-error-cliente-a-fin</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="revisar-datos-entrada" name="📋 Revisar Datos de Entrada">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>flujo-gestion-cliente-a-revisar-datos</bpmn:incoming>
      <bpmn:outgoing>flujo-revisar-datos-a-proceso-reserva</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:subProcess id="subprocess-proceso-reserva" name="🎟️ Proceso de Reserva">
      <bpmn:incoming>flujo-revisar-datos-a-proceso-reserva</bpmn:incoming>
      <bpmn:outgoing>flujo-proceso-reserva-a-gateway</bpmn:outgoing>
      <bpmn:startEvent id="reserva-inicio" name="Comenzar Proceso de Reserva">
        <bpmn:outgoing>flujo-a-gateway-paralelo</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:parallelGateway id="gateway-inicio-paralelo">
        <bpmn:incoming>flujo-a-gateway-paralelo</bpmn:incoming>
        <bpmn:outgoing>flujo-a-introducir-vuelo</bpmn:outgoing>
        <bpmn:outgoing>flujo-a-introducir-hotel</bpmn:outgoing>
        <bpmn:outgoing>flujo-a-introducir-coche</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:userTask id="introducir-datos-vuelo" name="✈️ Introducir Datos del Vuelo">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:assignmentDefinition assignee="demo" />
          <zeebe:formDefinition formId="gestionar-reserva-vuelo" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-a-introducir-vuelo</bpmn:incoming>
        <bpmn:outgoing>flujo-introducir-a-reservar-vuelo</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="reservar-vuelo" name="Reservar Vuelo">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="reservar-vuelo" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-introducir-a-reservar-vuelo</bpmn:incoming>
        <bpmn:outgoing>flujo-vuelo-completado</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="cancelar-vuelo" name="Cancelar Vuelo" isForCompensation="true">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="cancelar-vuelo" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:boundaryEvent id="evento-compensacion-vuelo" attachedToRef="reservar-vuelo">
        <bpmn:compensateEventDefinition id="CompensateEventDef_Vuelo" />
      </bpmn:boundaryEvent>
      <bpmn:userTask id="introducir-datos-hotel" name="🏨 Introducir Datos del Hotel">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:assignmentDefinition assignee="demo" />
          <zeebe:formDefinition formId="gestionar-reserva-hotel" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-a-introducir-hotel</bpmn:incoming>
        <bpmn:outgoing>flujo-introducir-a-reservar-hotel</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="reservar-hotel" name="Reservar Hotel">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="reservar-hotel" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-introducir-a-reservar-hotel</bpmn:incoming>
        <bpmn:outgoing>flujo-hotel-completado</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="cancelar-hotel" name="Cancelar Hotel" isForCompensation="true">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="cancelar-hotel" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:boundaryEvent id="evento-compensacion-hotel" attachedToRef="reservar-hotel">
        <bpmn:compensateEventDefinition id="CompensateEventDef_Hotel" />
      </bpmn:boundaryEvent>
      <bpmn:userTask id="introducir-datos-coche" name="🚗 Introducir Datos del Coche">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:assignmentDefinition assignee="demo" />
          <zeebe:formDefinition formId="gestionar-reserva-coche" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-a-introducir-coche</bpmn:incoming>
        <bpmn:outgoing>flujo-introducir-a-reservar-coche</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="reservar-coche" name="Reservar Coche">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="reservar-coche" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-introducir-a-reservar-coche</bpmn:incoming>
        <bpmn:outgoing>flujo-coche-completado</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="cancelar-coche" name="Cancelar Coche" isForCompensation="true">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="cancelar-coche" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:boundaryEvent id="evento-compensacion-coche" attachedToRef="reservar-coche">
        <bpmn:compensateEventDefinition id="CompensateEventDef_Coche" />
      </bpmn:boundaryEvent>
      <bpmn:parallelGateway id="gateway-fin-paralelo">
        <bpmn:incoming>flujo-vuelo-completado</bpmn:incoming>
        <bpmn:incoming>flujo-hotel-completado</bpmn:incoming>
        <bpmn:incoming>flujo-coche-completado</bpmn:incoming>
        <bpmn:outgoing>flujo-reserva-completado</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:endEvent id="fin-reserva-completada" name="Reserva Completada">
        <bpmn:incoming>flujo-reserva-completado</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:subProcess id="subproceso-manejo-errores" name="Manejar Error Reserva" triggeredByEvent="true">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=motivoFallo" target="motivoFallo" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:startEvent id="error-reserva-inicio" name="Error Reserva">
          <bpmn:extensionElements>
            <zeebe:ioMapping>
              <zeebe:output source="=motivoFallo" target="motivoFallo" />
            </zeebe:ioMapping>
          </bpmn:extensionElements>
          <bpmn:outgoing>flujo-error-a-gateway</bpmn:outgoing>
          <bpmn:errorEventDefinition id="ErrorEventDef_ErrorReserva" />
        </bpmn:startEvent>
        <bpmn:parallelGateway id="gateway-compensar-inicio">
          <bpmn:incoming>flujo-error-a-gateway</bpmn:incoming>
          <bpmn:outgoing>flujo-a-compensar-vuelo</bpmn:outgoing>
          <bpmn:outgoing>flujo-a-compensar-hotel</bpmn:outgoing>
          <bpmn:outgoing>flujo-a-compensar-coche</bpmn:outgoing>
        </bpmn:parallelGateway>
        <bpmn:intermediateThrowEvent id="evento-compensar-vuelo" name="Vuelo">
          <bpmn:incoming>flujo-a-compensar-vuelo</bpmn:incoming>
          <bpmn:outgoing>flujo-vuelo-compensado</bpmn:outgoing>
          <bpmn:compensateEventDefinition id="CompensateThrow_Vuelo" />
        </bpmn:intermediateThrowEvent>
        <bpmn:intermediateThrowEvent id="evento-compensar-hotel" name="Hotel">
          <bpmn:incoming>flujo-a-compensar-hotel</bpmn:incoming>
          <bpmn:outgoing>flujo-hotel-compensado</bpmn:outgoing>
          <bpmn:compensateEventDefinition id="CompensateThrow_Hotel" />
        </bpmn:intermediateThrowEvent>
        <bpmn:intermediateThrowEvent id="evento-compensar-coche" name="Coche">
          <bpmn:incoming>flujo-a-compensar-coche</bpmn:incoming>
          <bpmn:outgoing>flujo-coche-compensado</bpmn:outgoing>
          <bpmn:compensateEventDefinition id="CompensateThrow_Coche" />
        </bpmn:intermediateThrowEvent>
        <bpmn:parallelGateway id="gateway-compensar-fin">
          <bpmn:incoming>flujo-vuelo-compensado</bpmn:incoming>
          <bpmn:incoming>flujo-hotel-compensado</bpmn:incoming>
          <bpmn:incoming>flujo-coche-compensado</bpmn:incoming>
          <bpmn:outgoing>flujo-a-error-fin</bpmn:outgoing>
        </bpmn:parallelGateway>
        <bpmn:endEvent id="error-reserva-fin" name="Compensación Completada">
          <bpmn:incoming>flujo-a-error-fin</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="flujo-error-a-gateway" sourceRef="error-reserva-inicio" targetRef="gateway-compensar-inicio" />
        <bpmn:sequenceFlow id="flujo-a-compensar-vuelo" sourceRef="gateway-compensar-inicio" targetRef="evento-compensar-vuelo" />
        <bpmn:sequenceFlow id="flujo-a-compensar-hotel" sourceRef="gateway-compensar-inicio" targetRef="evento-compensar-hotel" />
        <bpmn:sequenceFlow id="flujo-a-compensar-coche" sourceRef="gateway-compensar-inicio" targetRef="evento-compensar-coche" />
        <bpmn:sequenceFlow id="flujo-vuelo-compensado" sourceRef="evento-compensar-vuelo" targetRef="gateway-compensar-fin" />
        <bpmn:sequenceFlow id="flujo-hotel-compensado" sourceRef="evento-compensar-hotel" targetRef="gateway-compensar-fin" />
        <bpmn:sequenceFlow id="flujo-coche-compensado" sourceRef="evento-compensar-coche" targetRef="gateway-compensar-fin" />
        <bpmn:sequenceFlow id="flujo-a-error-fin" sourceRef="gateway-compensar-fin" targetRef="error-reserva-fin" />
      </bpmn:subProcess>
      <bpmn:subProcess id="subproceso-actualizar-tarjeta" name="Actualizar Información Tarjeta Crédito" triggeredByEvent="true">
        <bpmn:startEvent id="actualizar-tarjeta-inicio" name="Tarjeta Proporcionada" isInterrupting="false">
          <bpmn:outgoing>flujo-tarjeta-a-actualizar</bpmn:outgoing>
          <bpmn:messageEventDefinition id="MessageEventDef_ActualizarTarjeta" messageRef="Message_TarjetaProporcionada" />
        </bpmn:startEvent>
        <bpmn:serviceTask id="actualizar-informacion-tarjeta" name="Actualizar Información de Tarjeta de Crédito">
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="actualizar-informacion-tarjeta" />
          </bpmn:extensionElements>
          <bpmn:incoming>flujo-tarjeta-a-actualizar</bpmn:incoming>
          <bpmn:outgoing>flujo-tarjeta-a-fin</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="actualizar-tarjeta-fin" name="Información Actualizada">
          <bpmn:incoming>flujo-tarjeta-a-fin</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="flujo-tarjeta-a-actualizar" sourceRef="actualizar-tarjeta-inicio" targetRef="actualizar-informacion-tarjeta" />
        <bpmn:sequenceFlow id="flujo-tarjeta-a-fin" sourceRef="actualizar-informacion-tarjeta" targetRef="actualizar-tarjeta-fin" />
      </bpmn:subProcess>
      <bpmn:sequenceFlow id="flujo-a-gateway-paralelo" sourceRef="reserva-inicio" targetRef="gateway-inicio-paralelo" />
      <bpmn:sequenceFlow id="flujo-a-introducir-vuelo" sourceRef="gateway-inicio-paralelo" targetRef="introducir-datos-vuelo" />
      <bpmn:sequenceFlow id="flujo-introducir-a-reservar-vuelo" sourceRef="introducir-datos-vuelo" targetRef="reservar-vuelo" />
      <bpmn:sequenceFlow id="flujo-vuelo-completado" sourceRef="reservar-vuelo" targetRef="gateway-fin-paralelo" />
      <bpmn:sequenceFlow id="flujo-a-introducir-hotel" sourceRef="gateway-inicio-paralelo" targetRef="introducir-datos-hotel" />
      <bpmn:sequenceFlow id="flujo-introducir-a-reservar-hotel" sourceRef="introducir-datos-hotel" targetRef="reservar-hotel" />
      <bpmn:sequenceFlow id="flujo-hotel-completado" sourceRef="reservar-hotel" targetRef="gateway-fin-paralelo" />
      <bpmn:sequenceFlow id="flujo-a-introducir-coche" sourceRef="gateway-inicio-paralelo" targetRef="introducir-datos-coche" />
      <bpmn:sequenceFlow id="flujo-introducir-a-reservar-coche" sourceRef="introducir-datos-coche" targetRef="reservar-coche" />
      <bpmn:sequenceFlow id="flujo-coche-completado" sourceRef="reservar-coche" targetRef="gateway-fin-paralelo" />
      <bpmn:sequenceFlow id="flujo-reserva-completado" sourceRef="gateway-fin-paralelo" targetRef="fin-reserva-completada" />
      <bpmn:association id="asociacion-compensar-vuelo" associationDirection="One" sourceRef="evento-compensacion-vuelo" targetRef="cancelar-vuelo" />
      <bpmn:association id="asociacion-compensar-hotel" associationDirection="One" sourceRef="evento-compensacion-hotel" targetRef="cancelar-hotel" />
      <bpmn:association id="asociacion-compensar-coche" associationDirection="One" sourceRef="evento-compensacion-coche" targetRef="cancelar-coche" />
    </bpmn:subProcess>
    <bpmn:subProcess id="subproceso-compensacion-manual" name="Manejar Compensación" triggeredByEvent="true">
      <bpmn:startEvent id="compensacion-manual-inicio" name="Compensar Reserva" isInterrupting="false">
        <bpmn:outgoing>flujo-manual-a-compensar-vuelo</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDef_CompensarReserva" messageRef="Message_CompensarReserva" />
      </bpmn:startEvent>
      <bpmn:intermediateThrowEvent id="evento-manual-compensar-vuelo" name="Vuelo">
        <bpmn:incoming>flujo-manual-a-compensar-vuelo</bpmn:incoming>
        <bpmn:outgoing>flujo-manual-a-compensar-hotel</bpmn:outgoing>
        <bpmn:compensateEventDefinition id="CompensateManual_Vuelo" />
      </bpmn:intermediateThrowEvent>
      <bpmn:intermediateThrowEvent id="evento-manual-compensar-hotel" name="Hotel">
        <bpmn:incoming>flujo-manual-a-compensar-hotel</bpmn:incoming>
        <bpmn:outgoing>flujo-manual-a-compensar-coche</bpmn:outgoing>
        <bpmn:compensateEventDefinition id="CompensateManual_Hotel" />
      </bpmn:intermediateThrowEvent>
      <bpmn:intermediateThrowEvent id="evento-manual-compensar-coche" name="Coche">
        <bpmn:incoming>flujo-manual-a-compensar-coche</bpmn:incoming>
        <bpmn:outgoing>flujo-manual-a-actualizar</bpmn:outgoing>
        <bpmn:compensateEventDefinition id="CompensateManual_Coche" />
      </bpmn:intermediateThrowEvent>
      <bpmn:serviceTask id="actualizar-registro-cliente" name="Revertir Estado del Cliente">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="actualizar-estado-cliente" />
          <zeebe:ioMapping>
            <zeebe:input source="=&quot;ACTIVO&quot;" target="nuevoEstado" />
            <zeebe:input source="=clienteId" target="clienteId" />
            <zeebe:input source="=reservaId" target="reservaId" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>flujo-manual-a-actualizar</bpmn:incoming>
        <bpmn:outgoing>flujo-manual-a-fin</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="compensacion-manual-fin" name="Reserva Compensada">
        <bpmn:incoming>flujo-manual-a-fin</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="flujo-manual-a-compensar-vuelo" sourceRef="compensacion-manual-inicio" targetRef="evento-manual-compensar-vuelo" />
      <bpmn:sequenceFlow id="flujo-manual-a-compensar-hotel" sourceRef="evento-manual-compensar-vuelo" targetRef="evento-manual-compensar-hotel" />
      <bpmn:sequenceFlow id="flujo-manual-a-compensar-coche" sourceRef="evento-manual-compensar-hotel" targetRef="evento-manual-compensar-coche" />
      <bpmn:sequenceFlow id="flujo-manual-a-actualizar" sourceRef="evento-manual-compensar-coche" targetRef="actualizar-registro-cliente" />
      <bpmn:sequenceFlow id="flujo-manual-a-fin" sourceRef="actualizar-registro-cliente" targetRef="compensacion-manual-fin" />
    </bpmn:subProcess>
    <bpmn:exclusiveGateway id="gateway-resultado-reserva" name="¿Reserva Exitosa?" default="flujo-gateway-a-pago">
      <bpmn:incoming>flujo-proceso-reserva-a-gateway</bpmn:incoming>
      <bpmn:outgoing>flujo-gateway-a-notificar</bpmn:outgoing>
      <bpmn:outgoing>flujo-gateway-a-pago</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="call-activity-proceso-pago" name="💳 Proceso de Pago">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="subproceso-pago" propagateAllChildVariables="true" />
      </bpmn:extensionElements>
      <bpmn:incoming>flujo-gateway-a-pago</bpmn:incoming>
      <bpmn:outgoing>flujo-pago-a-fin-exitoso</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:boundaryEvent id="evento-error-proceso-pago" name="❌ Error Pago" attachedToRef="call-activity-proceso-pago">
      <bpmn:outgoing>flujo-error-pago-a-fin</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDef_ProcesoPago" />
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="notificar-cliente-reserva-fallida" name="📧 Notificar Cliente: Reserva Fallida">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notificar-reserva-fallida" />
      </bpmn:extensionElements>
      <bpmn:incoming>flujo-gateway-a-notificar</bpmn:incoming>
      <bpmn:outgoing>flujo-notificar-a-fin-reserva-fallida</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="evento-fin-solicitud-completada" name="✅ Solicitud de Viaje Completada">
      <bpmn:incoming>flujo-pago-a-fin-exitoso</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="evento-fin-error-pago" name="❌ Pago Fallido">
      <bpmn:incoming>flujo-error-pago-a-fin</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="evento-fin-reserva-fallida" name="❌ Reserva Fallida">
      <bpmn:incoming>flujo-notificar-a-fin-reserva-fallida</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flujo-inicio-a-validar-datos" sourceRef="evento-inicio-solicitud-reserva" targetRef="validar-datos-entrada" />
    <bpmn:sequenceFlow id="flujo-error-validacion-a-fin" sourceRef="evento-error-datos-invalidos" targetRef="evento-fin-datos-invalidos" />
    <bpmn:sequenceFlow id="flujo-validar-a-gestion-cliente" sourceRef="validar-datos-entrada" targetRef="call-activity-gestion-cliente" />
    <bpmn:sequenceFlow id="flujo-error-cliente-a-fin" sourceRef="evento-error-gestion-cliente" targetRef="evento-fin-error-gestion-cliente" />
